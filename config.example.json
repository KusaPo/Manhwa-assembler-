{
  "_comment": "Copy to config.json and fill in API keys: cp config.example.json config.json",

  "openai_api_key": "your-key-here",
  "openai_model": "gpt-4o-mini",

  "elevenlabs_api_key": "your-key-here",
  "elevenlabs_voice_id": "your-voice-id-here",

  "video_width": 1920,
  "video_height": 1080,
  "fps": 30,

  "voiceover_volume": 1.0,
  "bg_music_volume": 0.18,

  "zoom_intensity": 0.15,
  "fade_duration": 0.3,

  "blur_background": true,
  "blur_radius": 51,
  "blur_dim": 0.7,
  "foreground_scale": 0.95,

  "caption_font": "Arial-Bold",
  "caption_font_size": 48,
  "caption_color": "white",
  "caption_stroke_color": "black",
  "caption_stroke_width": 3,

  "inter_sentence_pause_ms": 0,
  "tts_speed": 1.0,
  "panels_per_segment_max": 2,
  "strip_slice_threshold": 240,
  "voice_chunk_cache_dir": "output/voice_chunks"
}
